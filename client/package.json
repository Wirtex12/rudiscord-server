{
  "name": "voxit-client",
  "version": "1.0.2",
  "description": "Voxit Messenger Client",
  "author": "Voxit",
  "main": "dist-electron/main.js",
  "type": "commonjs",
  "scripts": {
    "vite": "vite",
    "electron:compile": "tsc -p tsconfig.electron.json",
    "electron": "cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "electron:dev": "npm run electron:compile && concurrently -k -s first \"npm run vite\" \"wait-on -t 60000 http://localhost:5173 && npm run electron\"",
    "electron:manual": "npm run electron:compile && npm run electron",
    "build": "tsc && vite build",
    "electron:build": "npm run electron:compile && npm run build && electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "simple-peer": "^9.11.1",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/simple-peer": "^9.11.9",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^10.1.0",
    "electron": "^34.0.2",
    "electron-builder": "^26.8.1",
    "terser": "^5.46.0",
    "typescript": "^5.7.3",
    "vite": "^6.1.0",
    "wait-on": "^8.0.2"
  },
  "build": {
    "appId": "com.voxit.messenger",
    "productName": "Voxit",
    "compression": "maximum",
    "protocols": {
      "name": "Voxit Protocol",
      "schemes": [
        "voxit"
      ]
    },
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*.js",
      "dist-electron/**/*.json",
      "package.json",
      "!**/*.{map,ts,tsx,jsx,md,log}",
      "!**/node_modules/.bin/**",
      "!**/node_modules/.cache/**",
      "!**/__tests__/**",
      "!**/*.test.*",
      "!**/*.spec.*",
      "!**/.git/**",
      "!**/.vscode/**",
      "!**/docs/**",
      "!**/examples/**",
      "!**/test/**",
      "!**/tests/**",
      "!**/.vite/**",
      "!**/.cache/**",
      "!**/*.d.ts"
    ],
    "asar": true,
    "asarUnpack": [
      "**/node_modules/sharp/**/*",
      "**/node_modules/@(squirrel)*/**/*"
    ],
    "npmRebuild": true,
    "publish": {
      "provider": "github",
      "owner": "Wirtex12",
      "repo": "Voxit-",
      "private": false
    },
    "win": {
      "target": "nsis",
      "requestedExecutionLevel": "asInvoker",
      "icon": "electron/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Voxit"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.social-networking"
    }
  }
}
